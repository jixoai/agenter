{
  "name": "@agenter/cli-shell",
  "version": "0.0.0",
  "type": "module",
  "files": [
    "SPEC.md",
    "src"
  ],
  "bin": {
    "agenter-cli-shell": "./src/bin/agenter-cli-shell.ts"
  },
  "scripts": {
    "build:binary:macos-arm64": "bun build --compile --target=bun-darwin-arm64 --outfile dist/bin/agenter-cli-shell-macos-arm64 src/bin/agenter-cli-shell.ts",
    "build:binary:linux-amd64": "bun build --compile --target=bun-linux-x64 --outfile dist/bin/agenter-cli-shell-linux-amd64 src/bin/agenter-cli-shell.ts",
    "build:binary:windows-amd64": "bun build --compile --target=bun-windows-x64 --outfile dist/bin/agenter-cli-shell-windows-amd64.exe src/bin/agenter-cli-shell.ts",
    "build:binary": "bun run build:binary:macos-arm64 && bun run build:binary:linux-amd64 && bun run build:binary:windows-amd64",
    "test": "bun test test/cli-shell.test.ts test/tmux-host.test.ts test/room-app.test.ts test/top-layer-app.test.ts test/shell-pane-app.test.ts test/live-terminal-mirror.test.ts test/settings.test.ts --max-concurrency=1",
    "typecheck": "bunx tsc --noEmit"
  },
  "dependencies": {
    "@agenter/client-sdk": "workspace:*",
    "@agenter/product-extension-runtime": "workspace:*",
    "@agenter/terminal-transport-protocol": "workspace:*",
    "@agenter/termless-core": "workspace:*",
    "@opentui/core": "latest",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/yargs": "^17.0.35",
    "typescript": "latest"
  },
  "engines": {
    "bun": ">=1.3.10"
  },
  "publishConfig": {
    "access": "public"
  }
}
