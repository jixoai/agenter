{
  "name": "agenter",
  "version": "0.0.11",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/jixoai/agenter"
  },
  "files": [
    "CHANGELOG.md",
    "SPEC.md",
    "bin",
    "cli-wrapper.cjs",
    "install.cjs",
    "native-platform.cjs"
  ],
  "bin": {
    "agenter": "./bin/agenter.exe"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "postinstall": "node ./install.cjs",
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit"
  },
  "optionalDependencies": {
    "@jixoai/cli-darwin-arm64": "workspace:*",
    "@jixoai/cli-darwin-x64": "workspace:*",
    "@jixoai/cli-linux-arm64-gnu": "workspace:*",
    "@jixoai/cli-linux-arm64-musl": "workspace:*",
    "@jixoai/cli-linux-x64-gnu": "workspace:*",
    "@jixoai/cli-linux-x64-musl": "workspace:*",
    "@jixoai/cli-win32-arm64": "workspace:*",
    "@jixoai/cli-win32-x64": "workspace:*"
  },
  "devDependencies": {
    "@agenter/cli": "workspace:*",
    "@types/bun": "latest",
    "typescript": "latest"
  },
  "engines": {
    "bun": ">=1.3.10",
    "node": ">=18.0.0"
  }
}
