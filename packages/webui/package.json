{
  "name": "@agenter/webui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "lint:layout": "oxlint -c .oxlintrc.json src/lib && vitest run src/lib/scroll-contract.spec.ts src/lib/layout-law-contract.spec.ts",
    "typecheck": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test:unit": "vitest run --project server",
    "test:dom": "vitest run --project storybook",
    "test": "pnpm run test:unit && pnpm run test:dom",
    "preview:toolbar": "vite dev --config toolbar-preview.vite.config.ts --host 127.0.0.1 --port 4174",
    "perf:reverse-flow-conversation": "bun run ./scripts/perf/reverse-flow-conversation/collect.ts",
    "e2e": "playwright test",
    "storybook": "storybook dev --ci --no-open --port 6006",
    "storybook:build": "storybook build"
  },
  "exports": {
    ".": "./src/lib/index.ts"
  },
  "dependencies": {
    "@agenter/client-sdk": "workspace:*",
    "@agenter/settings": "workspace:*",
    "@agenter/svelte-components": "workspace:*",
    "@agenter/terminal-view": "workspace:*",
    "@agenter/web-chat-view": "workspace:*",
    "@agenter/web-components": "workspace:*",
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/language": "^6.12.3",
    "@codemirror/language-data": "^6.5.1",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.0",
    "@fontsource-variable/ibm-plex-sans": "^5.2.6",
    "@fontsource-variable/jetbrains-mono": "^5.2.6",
    "@internationalized/date": "^3.12.0",
    "@lezer/highlight": "^1.2.3",
    "@lucide/svelte": "^1.7.0",
    "@tanstack/svelte-virtual": "^3.13.23",
    "bits-ui": "^2.16.3",
    "clsx": "^2.1.1",
    "highlight.js": "^11.11.1",
    "idb-keyval": "^6.2.2",
    "lit": "^3.3.1",
    "markdown-it": "^14.1.0",
    "shadcn-svelte": "^1.0.6",
    "tailwind-merge": "^3.3.1",
    "tailwind-variants": "^3.2.2",
    "tw-animate-css": "^1.4.0",
    "viem": "^2.47.6",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.1.1",
    "@playwright/test": "^1.58.2",
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/addon-svelte-csf": "^5.1.2",
    "@storybook/addon-vitest": "^10.3.5",
    "@storybook/sveltekit": "^10.3.5",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.56.1",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/bun": "latest",
    "@types/node": "^24",
    "@vitest/browser-playwright": "^4.1.0",
    "@vitest/coverage-v8": "^4.1.0",
    "oxlint": "^1.58.0",
    "playwright": "^1.59.0",
    "storybook": "^10.3.5",
    "svelte": "^5.55.2",
    "svelte-check": "^4.4.2",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.3",
    "vitest": "^4.1.0"
  }
}
