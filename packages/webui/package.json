{
  "name": "@agenter/webui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "typecheck": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test:unit": "vitest run --project server",
    "test:dom": "vitest run --project storybook",
    "test": "pnpm run test:unit && pnpm run test:dom",
    "e2e": "playwright test",
    "storybook": "storybook dev --ci --no-open --port 6006",
    "storybook:build": "storybook build"
  },
  "exports": {
    ".": "./src/lib/index.ts"
  },
  "dependencies": {
    "@agenter/client-sdk": "workspace:*",
    "@agenter/svelte-primitives": "workspace:*",
    "@agenter/web-components": "workspace:*",
    "@agenter/web-chat-view": "workspace:*",
    "@agenter/terminal-view": "workspace:*",
    "@fontsource-variable/ibm-plex-sans": "^5.2.6",
    "@fontsource-variable/jetbrains-mono": "^5.2.6",
    "@internationalized/date": "^3.12.0",
    "@lucide/svelte": "^1.7.0",
    "bits-ui": "^2.16.3",
    "clsx": "^2.1.1",
    "idb-keyval": "^6.2.2",
    "shadcn-svelte": "^1.0.6",
    "tailwind-merge": "^3.3.1",
    "tailwind-variants": "^3.2.2",
    "tw-animate-css": "^1.4.0",
    "viem": "^2.47.6"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.1.1",
    "@playwright/test": "^1.58.2",
    "@storybook/addon-a11y": "^10.3.3",
    "@storybook/addon-docs": "^10.3.3",
    "@storybook/addon-svelte-csf": "^5.1.2",
    "@storybook/addon-vitest": "^10.3.3",
    "@storybook/sveltekit": "^10.3.3",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.50.2",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/vite": "^4.1.18",
    "@types/bun": "latest",
    "@types/node": "^24",
    "@vitest/browser-playwright": "^4.1.0",
    "@vitest/coverage-v8": "^4.1.0",
    "playwright": "^1.59.0",
    "storybook": "^10.3.3",
    "svelte": "^5.54.0",
    "svelte-check": "^4.4.2",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.1.0"
  }
}
