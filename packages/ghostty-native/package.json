{
  "name": "@jixo/ghostty-native",
  "version": "0.3.3",
  "description": "Native Ghostty backend for termless — libghostty-vt via Zig napigen N-API bindings",
  "keywords": [
    "ghostty",
    "headless",
    "libghostty",
    "native",
    "terminal",
    "terminal-emulator",
    "terminal-testing",
    "tui",
    "vt-parser",
    "zig"
  ],
  "homepage": "https://termless.dev/",
  "bugs": {
    "url": "https://github.com/beorn/termless/issues"
  },
  "license": "MIT",
  "author": "Beorn",
  "repository": {
    "type": "git",
    "url": "https://github.com/beorn/termless.git",
    "directory": "packages/ghostty-native"
  },
  "files": [
    "README.md",
    "src"
  ],
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build:ghostty-native": "bash build/build.sh",
    "typecheck": "bunx tsc -p tsconfig.typecheck.json --noEmit"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^24"
  },
  "peerDependencies": {
    "@termless/core": "*"
  },
  "optionalDependencies": {
    "@jixo/ghostty-native-darwin-arm64": "workspace:*",
    "@jixo/ghostty-native-darwin-x64": "workspace:*",
    "@jixo/ghostty-native-linux-arm64-gnu": "workspace:*",
    "@jixo/ghostty-native-linux-x64-gnu": "workspace:*",
    "@jixo/ghostty-native-win32-arm64-msvc": "workspace:*",
    "@jixo/ghostty-native-win32-x64-msvc": "workspace:*"
  },
  "engines": {
    "bun": ">=1.0.0",
    "node": ">=23.6.0"
  }
}
