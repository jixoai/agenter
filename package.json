{
  "name": "agenter-workspace",
  "private": true,
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "demo",
    "apps/shell",
    "apps/studio",
    "packages/agenter",
    "packages/agenter-cli-darwin-arm64",
    "packages/agenter-cli-darwin-x64",
    "packages/agenter-cli-linux-arm64-gnu",
    "packages/agenter-cli-linux-arm64-musl",
    "packages/agenter-cli-linux-x64-gnu",
    "packages/agenter-cli-linux-x64-musl",
    "packages/agenter-cli-win32-arm64",
    "packages/agenter-cli-win32-x64",
    "packages/app-runtime",
    "packages/app-server",
    "packages/attention-system",
    "packages/auth-cli",
    "packages/auth-service",
    "packages/avatar",
    "packages/cli",
    "packages/client-sdk",
    "packages/ghostty-native",
    "packages/ghostty-native-darwin-arm64",
    "packages/ghostty-native-darwin-x64",
    "packages/ghostty-native-linux-arm64-gnu",
    "packages/ghostty-native-linux-x64-gnu",
    "packages/ghostty-native-win32-arm64-msvc",
    "packages/ghostty-native-win32-x64-msvc",
    "packages/i18n-core",
    "packages/i18n-en",
    "packages/i18n-zh-Hans",
    "packages/icon-studio",
    "packages/just-bash-overlay-rule-fs",
    "packages/loopbus-kernel",
    "packages/managed-seat-invitation-handshake",
    "packages/mdx2md",
    "packages/message-system",
    "packages/note-system",
    "packages/principal-crypto",
    "packages/profile-cli",
    "packages/profile-service",
    "packages/reactive-fs",
    "packages/search-syntax",
    "packages/session-system",
    "packages/settings",
    "packages/svelte-components",
    "packages/task-system",
    "packages/terminal-system",
    "packages/terminal-transport-protocol",
    "packages/terminal-view",
    "packages/termless-backend-utils",
    "packages/termless-core",
    "packages/tmux-client",
    "packages/web-chat-view",
    "packages/web-chat-view/example",
    "packages/web-components"
  ],
  "devDependencies": {
    "@changesets/cli": "^2.29.6",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-tailwindcss": "^0.7.2"
  },
  "scripts": {
    "agenter": "bun run packages/cli/src/bin/agenter.ts",
    "build:i18n": "bun run --cwd packages/i18n-en build && bun run --cwd packages/i18n-zh-Hans build",
    "build:icon-masters": "bun run ./assets/scripts/build-icon-masters.ts",
    "build:icons": "bun run build:icon-masters && bun run ./assets/scripts/generate-app-icons.ts",
    "build:icon-studio-lucide": "bun run ./assets/scripts/build-icon-studio-lucide-catalog.ts",
    "build:icon-studio": "bun run --filter '@agenter/icon-studio' build",
    "build:studio": "bun run --filter 'agenter-app-studio' build",
    "changeset": "changeset",
    "flutter-chat-view:web": "bun run packages/flutter-chat-view/example/scripts/run-web.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "homebrew:bootstrap-tap": "bun run scripts/homebrew/bootstrap-tap.ts",
    "npm:bootstrap-package": "bun run scripts/npm/bootstrap-package.ts",
    "openspec:vision": "bun run scripts/openspec/vision-driven.ts",
    "release:build-bundles": "bun run scripts/release/build-bundles.ts",
    "release:build-bundles:host-smoke": "bun run scripts/release/build-bundles.ts --host-only-smoke",
    "release:build-native-cli:all-targets": "bun run scripts/binaries/build-agenter-cli.ts --all-targets --stage-package",
    "release:build-native-cli:host-smoke": "bun run scripts/binaries/build-agenter-cli.ts --stage-package",
    "release:preflight": "bun run scripts/release/preflight.ts",
    "release:publish-bundles": "bun run scripts/release/publish-bundles.ts",
    "release:publish-bundles:dry-run": "bun run scripts/release/publish-bundles.ts --dry-run",
    "release:verify-native-cli-packages": "bun run scripts/release/verify-agenter-cli-packages.ts",
    "release:verify-published": "bun run scripts/release/verify-published.ts",
    "release-packages": "bun run release:build-bundles && bun run release:publish-bundles && bun run release:verify-published",
    "trusted-publish:check": "bun run scripts/npm/configure-trusted-publish.ts --check",
    "trusted-publish:configure": "bun run scripts/npm/configure-trusted-publish.ts",
    "trusted-publish:dry-run": "bun run scripts/npm/configure-trusted-publish.ts --dry-run",
    "typecheck": "bun run --filter '*' typecheck",
    "test": "bun run --filter '*' test",
    "version-packages": "changeset version"
  },
  "overrides": {
    "@codemirror/autocomplete": "6.20.1",
    "@codemirror/lang-html": "6.4.11",
    "@codemirror/lang-markdown": "6.5.0",
    "@codemirror/language": "6.12.3",
    "@codemirror/language-data": "6.5.1",
    "@codemirror/state": "6.6.0",
    "@codemirror/view": "6.41.0"
  },
  "dependencies": {
    "@agenter/icon-studio": "workspace:*",
    "imagetracerjs": "^1.2.6",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0",
    "sharp": "^0.34.5",
    "svgo": "^4.0.1"
  },
  "patchedDependencies": {
    "@termless/xtermjs@0.3.1": "patches/@termless+xtermjs@0.3.1.patch"
  }
}
