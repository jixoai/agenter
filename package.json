{
  "name": "agenter-workspace",
  "private": true,
  "workspaces": [
    "demo",
    "extensions/*",
    "packages/*"
  ],
  "devDependencies": {
    "@changesets/cli": "^2.29.6",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-tailwindcss": "^0.7.2"
  },
  "scripts": {
    "agenter": "bun run packages/cli/src/bin/agenter.ts",
    "build:i18n": "bun run --filter '@agenter/i18n-*' build",
    "build:icon-masters": "bun run ./assets/scripts/build-icon-masters.ts",
    "build:icons": "bun run build:icon-masters && bun run ./assets/scripts/generate-app-icons.ts",
    "build:icon-studio-lucide": "bun run ./assets/scripts/build-icon-studio-lucide-catalog.ts",
    "build:icon-studio": "bun run --filter '@agenter/icon-studio' build",
    "build:studio": "bun run --filter 'agenter-ext-studio' build",
    "changeset": "changeset",
    "flutter-chat-view:web": "bun run packages/flutter-chat-view/example/scripts/run-web.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "release:build-bundles": "bun run scripts/release/build-bundles.ts",
    "release:publish-bundles": "bun run scripts/release/publish-bundles.ts",
    "release:publish-bundles:dry-run": "bun run scripts/release/publish-bundles.ts --dry-run",
    "release-packages": "bun run release:build-bundles && bun run release:publish-bundles",
    "typecheck": "bun run --filter '*' typecheck",
    "test": "bun run --filter '*' test",
    "version-packages": "changeset version"
  },
  "overrides": {
    "@codemirror/autocomplete": "6.20.1",
    "@codemirror/lang-html": "6.4.11",
    "@codemirror/lang-markdown": "6.5.0",
    "@codemirror/language": "6.12.3",
    "@codemirror/language-data": "6.5.1",
    "@codemirror/state": "6.6.0",
    "@codemirror/view": "6.41.0"
  },
  "dependencies": {
    "@agenter/icon-studio": "workspace:*",
    "imagetracerjs": "^1.2.6",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0",
    "sharp": "^0.34.5",
    "svgo": "^4.0.1"
  },
  "patchedDependencies": {
    "@termless/xtermjs@0.3.1": "patches/@termless+xtermjs@0.3.1.patch"
  }
}
