{
  "agentCwd": "./tmp",
  "terminal": {
    "presets": {
      "iflow": {
        "command": ["iflow"],
        "submitGapMs": 120,
        "helpSource": "./.agenter/man/iflow.md"
      }
    },
    "outputRoot": "./logs/terminal",
    "gitLog": "normal"
  },
  "features": {
    "terminal": {
      "bootTerminals": [{ "id": "iflow", "focus": true, "autoRun": true }],
      "focusMode": "exclusive",
      "unfocusedSignal": "summary"
    }
  },
  "prompt": {
    "agenterPath": "./.agenter/AGENTER.mdx"
  },
  "ai": {
    "provider": "deepseek",
    "apiKeyEnv": "DEEPSEEK_API_KEY",
    "model": "deepseek-chat",
    "baseUrl": "https://api.deepseek.com/v1",
    "temperature": 0.2,
    "maxRetries": 2
  }
}
