{
  "name": "@agenter/demo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch run src/index.tsx",
    "start": "bun run src/index.tsx",
    "dev:terminal-devtools": "bun --watch run src/index.terminal-devtools.tsx",
    "start:terminal-devtools": "bun run src/index.terminal-devtools.tsx",
    "dev:iflow-devtools": "bun --watch run src/index.iflow-devtools.tsx",
    "start:iflow-devtools": "bun run src/index.iflow-devtools.tsx",
    "diagnose:terminal-crash": "bun run scripts/repro-iflow-crash.ts",
    "diagnose:iflow-crash": "bun run scripts/repro-iflow-crash.ts",
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit"
  },
  "dependencies": {
    "@opentui/core": "latest",
    "@opentui/react": "latest",
    "@xterm/headless": "latest",
    "react": "^19.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.0.0",
    "typescript": "latest"
  }
}
