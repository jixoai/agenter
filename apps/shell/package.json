{
  "name": "agenter-app-shell",
  "version": "0.0.4",
  "type": "module",
  "files": [
    "SPEC.md",
    "src"
  ],
  "bin": {
    "agenter-shell": "./src/bin/agenter-shell.ts"
  },
  "exports": {
    ".": "./src/index.ts",
    "./ShellAssistant.mdx": "./src/app-runtime/ShellAssistant.mdx",
    "./package.json": "./package.json"
  },
  "scripts": {
    "demo:renderer-grid": "bun run src/bin/agenter-shell.ts renderer-grid-demo",
    "test": "bun test test/*.test.ts",
    "typecheck": "bunx tsc --noEmit"
  },
  "dependencies": {
    "@agenter/client-sdk": "workspace:*",
    "@agenter/app-runtime": "workspace:*",
    "@agenter/terminal-transport-protocol": "workspace:*",
    "@agenter/termless-backend-utils": "workspace:*",
    "@agenter/termless-core": "workspace:*",
    "@opentui/core": "0.3.0",
    "yargs": "^17.7.2"
  },
  "peerDependencies": {
    "agenter": ">=0.0.10 <0.1.0"
  },
  "keywords": [
    "agenter-app"
  ],
  "agenter": {
    "app": {
      "appId": "shell",
      "command": "shell",
      "bin": "agenter-shell",
      "descriptor": "./src/app-runtime/app.ts"
    }
  },
  "devDependencies": {
    "agenter": "workspace:*",
    "@types/bun": "latest",
    "@types/yargs": "^17.0.35",
    "typescript": "latest"
  },
  "engines": {
    "bun": ">=1.3.10"
  },
  "publishConfig": {
    "access": "public"
  }
}
